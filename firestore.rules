rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /volunteers/{docId} {
      allow read, write: if true;
    }
    match /clinicNeeds/{docId} {
      allow read, write: if true;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
