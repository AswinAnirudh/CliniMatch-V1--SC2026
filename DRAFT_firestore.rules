rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    // Check if the user is an admin (Simplified for prototype: we check if they exist in /admins/)
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- Entity Validations ---

    function isValidVolunteer(data) {
      return data.keys().hasAll(['name', 'specialty', 'location', 'availability'])
        && data.keys().size() == 4
        && data.name is string && data.name.size() >= 1 && data.name.size() <= 100
        && data.specialty is string && data.specialty.size() >= 1 && data.specialty.size() <= 100
        && data.location is string && data.location.size() >= 1 && data.location.size() <= 100
        && data.availability is string && data.availability.size() >= 1 && data.availability.size() <= 200;
    }

    function isValidClinicNeed(data) {
      return data.keys().hasAll(['description', 'createdAt'])
        && data.keys().size() == 2
        && data.description is string && data.description.size() >= 1 && data.description.size() <= 1000
        && data.createdAt == request.time;
    }

    // --- Collections ---

    match /volunteers/{userId} {
      // For the prototype, we allow public read so the AI can match. 
      // In a real app, this should be restricted to the clinic admin.
      allow read: if true; 
      
      allow create: if isValidVolunteer(incoming());
      
      allow update: if (
        isValidVolunteer(incoming()) && (
          // Allow full update if name/details change, as long as it's still valid
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'specialty', 'location', 'availability'])
        )
      );
    }

    match /clinicNeeds/{needId} {
      allow read: if true;
      allow create: if isValidClinicNeed(incoming());
    }
    
    // Admins collection (Read-only for the admin themselves)
    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
